# Copy this file to .env on the server or local machine.
# Never commit real .env to Git.

WIALON_TOKEN=put_your_wialon_token_here
WIALON_HOST=https://hst-api.wialon.com

# Optional override. If empty, app uses tracked_bus.unit_id from route_config.json.
TRACKED_BUS_ID=
TRACKED_BUS_NAME=

ROUTE_CONFIG=route_config.json
